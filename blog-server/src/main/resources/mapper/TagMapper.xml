<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.TagMapper">

    <select id="findAll" resultType="com.blog.entity.Tag">
        SELECT * FROM tag ORDER BY id
    </select>

    <select id="findByName" resultType="com.blog.entity.Tag">
        SELECT * FROM tag WHERE name = #{name}
    </select>

    <insert id="insert" parameterType="com.blog.entity.Tag" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tag (name) VALUES (#{name})
    </insert>

    <delete id="deleteById">
        DELETE FROM tag WHERE id = #{id}
    </delete>
</mapper>
